<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Class Animation Library</title>
  <meta
    name="description"
    content="A customizable GitHub Pages landing page for biology and earth science animations."
  />

  <style>
    /*
      CUSTOMIZE COLORS HERE
      Change these CSS variables to quickly adjust the whole site.
    */
    :root {
      --bg: #f6f8fb;
      --panel: #ffffff;
      --text: #1f2937;
      --muted: #6b7280;
      --border: #d7dde8;
      --accent: #2563eb;
      --accent-dark: #1e40af;
      --accent-soft: #dbeafe;
      --card-shadow: 0 10px 25px rgba(31, 41, 55, 0.08);
      --radius: 18px;
      --max-width: 1180px;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at top left, rgba(37, 99, 235, 0.12), transparent 34rem),
        var(--bg);
      color: var(--text);
      line-height: 1.5;
    }

    a {
      color: inherit;
    }

    .site-header {
      background: linear-gradient(135deg, #0f172a, #1d4ed8);
      color: white;
      padding: 3rem 1.25rem 2.5rem;
    }

    .header-inner,
    main,
    .footer-inner {
      width: min(var(--max-width), calc(100% - 2rem));
      margin: 0 auto;
    }

    .credit {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.45rem 0.75rem;
      border: 1px solid rgba(255, 255, 255, 0.28);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.12);
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }

    .site-header h1 {
      font-size: clamp(2.2rem, 5vw, 4.75rem);
      line-height: 0.98;
      letter-spacing: -0.06em;
      margin: 0 0 1rem;
      max-width: 840px;
    }

    .site-header p {
      margin: 0;
      max-width: 760px;
      color: rgba(255, 255, 255, 0.84);
      font-size: clamp(1rem, 2vw, 1.25rem);
    }

    .toolbar {
      margin-top: -1.6rem;
      position: sticky;
      top: 0;
      z-index: 20;
      padding: 0 0 1rem;
    }

    .toolbar-inner {
      width: min(var(--max-width), calc(100% - 2rem));
      margin: 0 auto;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(12px);
      border: 1px solid var(--border);
      box-shadow: var(--card-shadow);
      border-radius: var(--radius);
      padding: 1rem;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 0.8rem;
      align-items: center;
    }

    .search-wrap {
      position: relative;
    }

    .search-wrap input {
      width: 100%;
      appearance: none;
      border: 1px solid var(--border);
      background: white;
      color: var(--text);
      border-radius: 999px;
      padding: 0.85rem 1rem 0.85rem 2.6rem;
      font-size: 1rem;
      outline: none;
    }

    .search-wrap input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 4px var(--accent-soft);
    }

    .search-icon {
      position: absolute;
      left: 0.95rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--muted);
    }

    .category-jump {
      display: flex;
      gap: 0.45rem;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .category-jump a,
    .filter-button {
      border: 1px solid var(--border);
      background: white;
      color: var(--text);
      border-radius: 999px;
      padding: 0.55rem 0.75rem;
      text-decoration: none;
      font-size: 0.9rem;
      cursor: pointer;
      transition: 0.18s ease;
    }

    .category-jump a:hover,
    .filter-button:hover,
    .filter-button.active {
      border-color: var(--accent);
      background: var(--accent-soft);
      color: var(--accent-dark);
    }

    main {
      padding: 2rem 0 4rem;
    }

    .notice {
      background: #fff7ed;
      border: 1px solid #fed7aa;
      color: #7c2d12;
      border-radius: var(--radius);
      padding: 1rem 1.1rem;
      margin-bottom: 1.5rem;
    }

    .notice strong {
      color: #7c2d12;
    }

    .category-section {
      margin: 2rem 0 3rem;
      scroll-margin-top: 8rem;
    }

    .category-heading {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1rem;
      border-bottom: 1px solid var(--border);
      padding-bottom: 0.75rem;
    }

    .category-heading h2 {
      margin: 0;
      font-size: clamp(1.45rem, 3vw, 2.15rem);
      letter-spacing: -0.035em;
    }

    .count {
      color: var(--muted);
      white-space: nowrap;
      font-size: 0.95rem;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }

    .animation-card {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--card-shadow);
      padding: 1.05rem;
      display: flex;
      flex-direction: column;
      min-height: 230px;
    }

    .animation-card h3 {
      font-size: 1.12rem;
      line-height: 1.2;
      margin: 0 0 0.55rem;
      letter-spacing: -0.02em;
    }

    .animation-card p {
      margin: 0 0 0.9rem;
      color: var(--muted);
      font-size: 0.96rem;
    }

    .tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin-top: auto;
      margin-bottom: 1rem;
    }

    .tag {
      font-size: 0.78rem;
      color: var(--accent-dark);
      background: var(--accent-soft);
      border-radius: 999px;
      padding: 0.25rem 0.5rem;
    }

    .card-link {
      display: inline-flex;
      justify-content: center;
      align-items: center;
      text-decoration: none;
      background: var(--accent);
      color: white;
      border-radius: 999px;
      padding: 0.7rem 0.9rem;
      font-weight: 650;
      transition: 0.18s ease;
    }

    .card-link:hover {
      background: var(--accent-dark);
      transform: translateY(-1px);
    }

    .empty-card {
      border: 1px dashed var(--border);
      background: rgba(255, 255, 255, 0.65);
      color: var(--muted);
      border-radius: var(--radius);
      padding: 1.1rem;
    }

    .empty-card h3 {
      color: var(--text);
      margin-top: 0;
    }

    .site-footer {
      border-top: 1px solid var(--border);
      padding: 2rem 1rem;
      color: var(--muted);
      background: white;
    }

    .site-footer code,
    .notice code {
      background: rgba(15, 23, 42, 0.08);
      padding: 0.1rem 0.25rem;
      border-radius: 0.35rem;
    }

    .hidden {
      display: none !important;
    }

    @media (max-width: 980px) {
      .toolbar-inner {
        grid-template-columns: 1fr;
      }

      .category-jump {
        justify-content: flex-start;
      }

      .grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 640px) {
      .site-header {
        padding-top: 2.25rem;
      }

      .toolbar {
        position: static;
        margin-top: -1rem;
      }

      .grid {
        grid-template-columns: 1fr;
      }

      .category-heading {
        align-items: flex-start;
        flex-direction: column;
      }
    }
  </style>
</head>

<body>
  <header class="site-header">
    <div class="header-inner">
      <div class="credit">Animation by Jerred Seveyka for his biology class</div>
      <h1>Interactive Class Animation Library</h1>
      <p>
        A growing collection of browser-based biology, anatomy, microbiology, genetics,
        and earth science animations for students.
      </p>
    </div>
  </header>

  <section class="toolbar" aria-label="Search and category shortcuts">
    <div class="toolbar-inner">
      <div class="search-wrap">
        <span class="search-icon" aria-hidden="true">⌕</span>
        <input
          id="searchInput"
          type="search"
          placeholder="Search animations by title, topic, or tag..."
          aria-label="Search animations"
        />
      </div>
      <nav class="category-jump" id="categoryJump" aria-label="Animation categories"></nav>
    </div>
  </section>

  <main>
    <div class="notice">
      <strong>How to customize:</strong>
      put your finished animation HTML files in an <code>animations</code> folder,
      then edit the <code>animations</code> list near the bottom of this file.
      Replace placeholder filenames such as <code>animations/spirometry.html</code>
      with your actual filenames.
    </div>

    <div id="library"></div>
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <p>
        This page is a static GitHub Pages landing page. It uses only HTML, CSS,
        and JavaScript, so it should work on laptops, tablets, Chromebooks, iPads,
        and modern mobile browsers.
      </p>
    </div>
  </footer>

  <script>
    /*
      ADD OR EDIT CATEGORIES HERE
      Keep the category names matched to the category field in each animation below.
    */
    const categories = [
      "Neurons",
      "Respiratory System",
      "Cardiovascular System",
      "Reproductive System",
      "Tissues",
      "Immune System",
      "Climate and Earth dynamics",
      "Microbiology",
      "Molecular Genetics",
      "Life Cycles"
    ];

    /*
      ADD OR EDIT ANIMATIONS HERE

      file:
        Use a relative path such as "animations/spirometry.html".
        If your animation file is in the same folder as this page, use "spirometry.html".

      tags:
        Short search terms that help students find the animation.

      To add a new animation, copy one object, paste it below, and edit the fields.
    */
    const animations = [
      {
        title: "Spirometry and Lung Volumes",
        category: "Respiratory System",
        description: "Students manipulate lung volumes, forced expiration, FEV1, asthma, and emphysema patterns.",
        file: "animations/spirometry.html",
        tags: ["lungs", "FEV1", "asthma", "emphysema"]
      },
      {
        title: "Internal and External Respiration",
        category: "Respiratory System",
        description: "Oxygen and carbon dioxide movement between alveoli, blood, tissues, plasma, and red blood cells.",
        file: "animations/internal-external-respiration.html",
        tags: ["oxygen", "carbon dioxide", "RBC", "bicarbonate"]
      },
      {
        title: "Partial Pressures and Gas Solubility",
        category: "Respiratory System",
        description: "Interactive containers show how gas mixtures, pressure, and solubility affect dissolved gases.",
        file: "animations/partial-pressures-gas-solubility.html",
        tags: ["partial pressure", "solubility", "oxygen", "nitrogen"]
      },

      {
        title: "Ovarian Cycle Control",
        category: "Reproductive System",
        description: "Hypothalamus, anterior pituitary, FSH, LH, follicle development, ovulation, and corpus luteum formation.",
        file: "animations/ovarian-cycle.html",
        tags: ["FSH", "LH", "ovulation", "follicle"]
      },

      {
        title: "Tides: Sun, Moon, and Earth",
        category: "Climate and Earth dynamics",
        description: "Interactive model of tidal bulges, lunar influence, solar influence, and changing tidal range.",
        file: "animations/tides.html",
        tags: ["tides", "moon", "sun", "ocean"]
      },
      {
        title: "Coriolis Effect and Wind Belts",
        category: "Climate and Earth dynamics",
        description: "Students explore Earth rotation, curved wind vectors, surface currents, rain cells, and wind belts.",
        file: "animations/coriolis-effect.html",
        tags: ["coriolis", "wind", "currents", "earth"]
      },
      {
        title: "Ocean Acidification and Calcification",
        category: "Climate and Earth dynamics",
        description: "Carbon dioxide, carbonic acid, bicarbonate, hydrogen ions, carbonate, and calcium carbonate formation.",
        file: "animations/ocean-acidification-calcification.html",
        tags: ["CO2", "carbonic acid", "calcification", "carbonate"]
      },

      {
        title: "Horizontal Gene Transfer in Bacteria",
        category: "Microbiology",
        description: "Transformation, transduction, and conjugation shown as selectable bacterial gene-transfer pathways.",
        file: "animations/horizontal-gene-transfer.html",
        tags: ["transformation", "transduction", "conjugation", "bacteria"]
      },
      {
        title: "Urease, Urea, Ammonia, and pH",
        category: "Microbiology",
        description: "Urease breaks down urea into carbon dioxide and ammonia, followed by ammonia binding hydrogen ions.",
        file: "animations/urease.html",
        tags: ["urease", "urea", "ammonia", "pH"]
      },
      {
        title: "Primary, Secondary, and Tertiary Endosymbiosis",
        category: "Microbiology",
        description: "Cells engulf bacteria, cyanobacteria, and eukaryotic algae to form mitochondria and chloroplasts.",
        file: "animations/endosymbiosis.html",
        tags: ["mitochondria", "chloroplast", "eukaryote", "cyanobacteria"]
      },

      {
        title: "Alu SINE Copying by LINE Elements",
        category: "Molecular Genetics",
        description: "Shows transcription, reverse transcriptase borrowing, DNA formation, and insertion at a new genomic site.",
        file: "animations/alu-line-copying.html",
        tags: ["Alu", "SINE", "LINE", "reverse transcriptase"]
      },
      {
        title: "Gene Duplication and Gene Families",
        category: "Molecular Genetics",
        description: "Multiple duplication mechanisms including DNA break repair, retrotransposition, crossing over, nondisjunction, and whole-genome duplication.",
        file: "animations/gene-duplication.html",
        tags: ["gene family", "duplication", "meiosis", "genome"]
      },
      {
        title: "Post-Transcriptional and Post-Translational Control",
        category: "Molecular Genetics",
        description: "Alternative splicing, mRNA processing, microRNA, siRNA, poly-A shortening, ubiquitin, and protein degradation.",
        file: "animations/gene-expression-control.html",
        tags: ["splicing", "mRNA", "microRNA", "ubiquitin"]
      },
      {
        title: "Chromatin Compression and Decompression",
        category: "Molecular Genetics",
        description: "Histone acetylation, deacetylation, methylation, demethylation, and simplified chromatin remodeling.",
        file: "animations/chromatin-remodeling.html",
        tags: ["histone", "acetylation", "methylation", "chromatin"]
      },
      {
        title: "ABC-E Flower Pattern Genes",
        category: "Molecular Genetics",
        description: "Students knock out A, B, C, and E genes to see changes in sepals, petals, stamens, and carpels.",
        file: "animations/flower-pattern-genes.html",
        tags: ["flower", "ABCDE", "mutation", "whorls"]
      },

      {
        title: "Scyphozoan Jellyfish Life Cycle",
        category: "Life Cycles",
        description: "Aurelia-style jellyfish life cycle with larva, scyphostome, strobile, ephyra, and adult medusa stages.",
        file: "animations/jellyfish-life-cycle.html",
        tags: ["jellyfish", "Aurelia", "ephyra", "medusa"]
      },
      {
        title: "Ulva Life Cycle",
        category: "Life Cycles",
        description: "Alternation of generations with sporophyte, gametophyte, zoospores, egg, sperm, and ploidy labels.",
        file: "animations/ulva-life-cycle.html",
        tags: ["Ulva", "algae", "gametophyte", "sporophyte"]
      },
      {
        title: "Tapeworm Life Cycle",
        category: "Life Cycles",
        description: "Eggs, intermediate host, cysticercus in muscle, human infection, proglottids, and fecal egg release.",
        file: "animations/tapeworm-life-cycle.html",
        tags: ["tapeworm", "cysticercus", "proglottid", "parasite"]
      },
      {
        title: "Viral Life Cycles",
        category: "Life Cycles",
        description: "Students compare +RNA, -RNA, dsDNA, and retrovirus life cycles with enveloped or non-enveloped options.",
        file: "animations/viral-life-cycles.html",
        tags: ["virus", "RNA", "DNA", "retrovirus"]
      }
    ];

    const library = document.querySelector("#library");
    const categoryJump = document.querySelector("#categoryJump");
    const searchInput = document.querySelector("#searchInput");

    function slugify(text) {
      return text
        .toLowerCase()
        .replace(/&/g, "and")
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/(^-|-$)/g, "");
    }

    function createCategoryButtons() {
      categoryJump.innerHTML = "";

      const allButton = document.createElement("button");
      allButton.className = "filter-button active";
      allButton.textContent = "All";
      allButton.type = "button";
      allButton.addEventListener("click", () => {
        searchInput.value = "";
        document.querySelectorAll(".filter-button").forEach(button => button.classList.remove("active"));
        allButton.classList.add("active");
        renderLibrary();
      });
      categoryJump.appendChild(allButton);

      categories.forEach(category => {
        const link = document.createElement("a");
        link.href = `#${slugify(category)}`;
        link.textContent = category;
        categoryJump.appendChild(link);
      });
    }

    function matchesSearch(animation, query) {
      if (!query) return true;

      const searchableText = [
        animation.title,
        animation.category,
        animation.description,
        ...(animation.tags || [])
      ]
        .join(" ")
        .toLowerCase();

      return searchableText.includes(query.toLowerCase());
    }

    function createAnimationCard(animation) {
      const article = document.createElement("article");
      article.className = "animation-card";

      const title = document.createElement("h3");
      title.textContent = animation.title;

      const description = document.createElement("p");
      description.textContent = animation.description;

      const tags = document.createElement("div");
      tags.className = "tags";
      (animation.tags || []).forEach(tagText => {
        const tag = document.createElement("span");
        tag.className = "tag";
        tag.textContent = tagText;
        tags.appendChild(tag);
      });

      const link = document.createElement("a");
      link.className = "card-link";
      link.href = animation.file;
      link.textContent = "Open animation";

      article.append(title, description, tags, link);
      return article;
    }

    function createEmptyCard(category) {
      const div = document.createElement("div");
      div.className = "empty-card";
      div.innerHTML = `
        <h3>No animations added yet</h3>
        <p>Add an animation object with <code>category: "${category}"</code> in the JavaScript list.</p>
      `;
      return div;
    }

    function renderLibrary() {
      const query = searchInput.value.trim();
      library.innerHTML = "";

      categories.forEach(category => {
        const categoryAnimations = animations.filter(animation => {
          return animation.category === category && matchesSearch(animation, query);
        });

        if (query && categoryAnimations.length === 0) return;

        const section = document.createElement("section");
        section.className = "category-section";
        section.id = slugify(category);

        const heading = document.createElement("div");
        heading.className = "category-heading";

        const h2 = document.createElement("h2");
        h2.textContent = category;

        const count = document.createElement("div");
        count.className = "count";
        count.textContent = `${categoryAnimations.length} animation${categoryAnimations.length === 1 ? "" : "s"}`;

        heading.append(h2, count);

        const grid = document.createElement("div");
        grid.className = "grid";

        if (!query && categoryAnimations.length === 0) {
          grid.appendChild(createEmptyCard(category));
        } else {
          categoryAnimations.forEach(animation => {
            grid.appendChild(createAnimationCard(animation));
          });
        }

        section.append(heading, grid);
        library.appendChild(section);
      });

      if (!library.children.length) {
        library.innerHTML = `
          <div class="empty-card">
            <h3>No matching animations found</h3>
            <p>Try a different search term.</p>
          </div>
        `;
      }
    }

    searchInput.addEventListener("input", () => {
      document.querySelectorAll(".filter-button").forEach(button => button.classList.remove("active"));
      renderLibrary();
    });

    createCategoryButtons();
    renderLibrary();
  </script>
</body>
</html>
